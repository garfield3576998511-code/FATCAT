{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Chrome (pwa-chrome)",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:8080",
      "webRoot": "${workspaceFolder}/src",
      "runtimeExecutable": "C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe",
      "userDataDir": "${workspaceFolder}\\.vscode\\chrome-profile",
      "sourceMaps": true
    },
    {
      "name": "Attach to Chrome (pwa-chrome)",
      "type": "pwa-chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}/src",
      "sourceMaps": true
    }
  ]
}
